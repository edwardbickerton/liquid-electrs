+    fn flush_and_checkpoint(
+        &mut self,
+        tip: &BlockHash,
+        processed_headers: Vec<HeaderEntry>,
+        checkpoint_label: &str,
+    ) {
+        let t = std::time::Instant::now();
+        debug!("flushing txstore_db to disk");
+        self.store.txstore_db.flush();
+        debug!("flushing txstore_db complete in {:.1?}", t.elapsed());
+
+        let t = std::time::Instant::now();
+        debug!("flushing history_db to disk");
+        self.store.history_db.flush();
+        debug!("flushing history_db complete in {:.1?}", t.elapsed());
+
+        // cache_db receives WAL-disabled writes when --address-search is enabled,
+        // so it needs the same explicit flush to ensure durability.
+        let t = std::time::Instant::now();
+        debug!("flushing cache_db to disk");
+        self.store.cache_db.flush();
+        debug!("flushing cache_db complete in {:.1?}", t.elapsed());
+
+        self.flush = DBFlush::Enable;
+
+        debug!("updating synced tip to {:?}", tip);
+        self.store.txstore_db.put_sync(b"t", &serialize(tip));
+
+        let mut headers = self.store.indexed_headers.write().unwrap();
+        if !processed_headers.is_empty() {
+            headers.append(processed_headers);
+        }
+        assert_eq!(*tip, *headers.tip());
+
+        let durable_height = headers.best_height();
+        self.tip_metric.set(durable_height as i64);
+        info!(
+            "{}: durable tip height={} hash={:?}",
+            checkpoint_label,
+            durable_height,
+            tip,
+        );
+    }
+
+    fn process_header_window(
+        &mut self,
+        daemon: &Daemon,
+        headers: &[HeaderEntry],
+        run_compactions: bool,
+        checkpoint_label: &str,
+    ) -> Result<()> {
+        let to_add = self.headers_to_add(headers);
+        debug!(
+            "adding transactions from {} blocks using {:?}",
+            to_add.len(),
+            self.from
+        );
+
+        let mut fetcher_count = 0;
+        let mut blocks_fetched = 0;
+        let to_add_total = to_add.len();
+
+        start_fetcher(self.from, daemon, to_add)?.map(|blocks| {
+            if fetcher_count % 25 == 0 && to_add_total > 20 {
+                info!(
+                    "adding txes from blocks {}/{} ({:.1}%)",
+                    blocks_fetched,
+                    to_add_total,
+                    blocks_fetched as f32 / to_add_total as f32 * 100.0
+                );
+            }
+            fetcher_count += 1;
+            blocks_fetched += blocks.len();
+
+            self.add(&blocks)
+        });
+
+        if run_compactions {
+            self.start_auto_compactions(&self.store.txstore_db);
+        }
+
+        let to_index = self.headers_to_index(headers);
+        debug!(
+            "indexing history from {} blocks using {:?}",
+            to_index.len(),
+            self.from
+        );
+        start_fetcher(self.from, daemon, to_index)?.map(|blocks| self.index(&blocks));
+        if run_compactions {
+            self.start_auto_compactions(&self.store.history_db);
+            self.start_auto_compactions(&self.store.cache_db);
+        }
+
+        let batch_tip = *headers.last().unwrap().hash();
+        self.flush_and_checkpoint(&batch_tip, headers.to_vec(), checkpoint_label);
+        Ok(())
+    }
