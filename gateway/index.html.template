<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Liquid Electrs</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #071217;
      --panel: rgba(8, 23, 29, 0.9);
      --panel-strong: rgba(4, 15, 19, 0.94);
      --border: rgba(116, 241, 197, 0.2);
      --text: #f6fff9;
      --muted: #a4c4bc;
      --accent: #00d18c;
      --accent-strong: #7af7ca;
      --shadow: 0 28px 70px rgba(0, 0, 0, 0.42);
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Chakra Petch", "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(0, 209, 140, 0.18), transparent 36%),
        radial-gradient(circle at bottom right, rgba(122, 247, 202, 0.12), transparent 28%),
        linear-gradient(145deg, #020a0d, var(--bg));
    }

    main {
      width: min(960px, calc(100% - 32px));
      margin: 0 auto;
      padding: 40px 0 56px;
    }

    .hero,
    .panel {
      border: 1px solid var(--border);
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(9, 26, 31, 0.94), var(--panel-strong));
      box-shadow: var(--shadow);
    }

    .hero {
      padding: 28px;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 14px;
      padding: 7px 12px;
      border-radius: 999px;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-strong);
      background: rgba(0, 209, 140, 0.12);
    }

    h1 {
      margin: 0;
      font-size: clamp(34px, 7vw, 58px);
      line-height: 0.95;
    }

    .lead {
      max-width: 640px;
      margin: 18px 0 0;
      color: var(--muted);
      font-size: 18px;
      line-height: 1.6;
    }

    .panel {
      margin-top: 24px;
      padding: 28px;
    }

    h2 {
      margin: 0;
      font-size: clamp(28px, 4vw, 38px);
      line-height: 1.05;
    }

    .support-copy {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 17px;
      line-height: 1.6;
      max-width: 620px;
    }

    .field {
      margin-top: 24px;
      padding: 18px;
      border: 1px solid rgba(122, 247, 202, 0.12);
      border-radius: 18px;
      background: rgba(0, 0, 0, 0.16);
    }

    .field-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .field-header span {
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .field-value {
      margin-top: 12px;
      font-family: "SFMono-Regular", "Menlo", monospace;
      font-size: 17px;
      font-weight: 700;
      color: var(--accent-strong);
      line-height: 1.45;
      word-break: break-word;
    }

    .copy-btn {
      border: 1px solid rgba(122, 247, 202, 0.18);
      border-radius: 999px;
      padding: 7px 12px;
      background: rgba(0, 209, 140, 0.08);
      color: var(--text);
      font: inherit;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
      cursor: pointer;
      transition: background 120ms ease, border-color 120ms ease, color 120ms ease;
    }

    .copy-btn:hover,
    .copy-btn:focus-visible {
      background: rgba(0, 209, 140, 0.16);
      border-color: rgba(122, 247, 202, 0.34);
      outline: none;
    }

    .copy-btn.copied {
      color: #03261a;
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      border-color: transparent;
    }

    .hint {
      margin-top: 24px;
      padding: 18px 20px;
      border-left: 3px solid var(--accent);
      border-radius: 16px;
      background: rgba(0, 209, 140, 0.08);
      color: var(--muted);
      line-height: 1.65;
    }

    .hint strong {
      color: var(--text);
    }

    @media (max-width: 720px) {
      main {
        width: min(100%, calc(100% - 24px));
        padding: 24px 0 40px;
      }

      .hero,
      .panel {
        padding: 22px;
        border-radius: 24px;
      }
    }
  </style>
</head>

<body>
  <main>
    <section class="hero">
      <div class="eyebrow">Umbrel Liquid Server</div>
      <h1>Connect Blockstream App to your own Liquid Electrum server.</h1>
      <p class="lead">
        This app runs a self-hosted Liquid Electrum endpoint using your Umbrel
        Elements app. Paste the server value below into Blockstream App desktop
        and leave TLS disabled.
      </p>
    </section>

    <section class="panel">
      <h2>Connection details</h2>
      <p class="support-copy">
        In Blockstream App desktop, choose your own server, paste this
        <code>host:port</code> value, and keep <strong>Enable TLS/SSL</strong>
        turned off.
      </p>

      <div class="field">
        <div class="field-header">
          <span>Liquid Electrum server</span>
          <button class="copy-btn" type="button" data-copy-target="server-value">
            Copy
          </button>
        </div>
        <div class="field-value" id="server-value">${LAN_HOSTNAME}:${PLAIN_PORT}</div>
      </div>

      <div class="hint">
        <strong>First sync can take time.</strong> If the server has just been
        installed, let the index finish building before testing wallet sync.
      </div>
    </section>
  </main>

  <script>
    const copyButton = document.querySelector("[data-copy-target]");
    const target = document.getElementById(copyButton.dataset.copyTarget);

    copyButton.addEventListener("click", async function () {
      const originalLabel = copyButton.textContent.trim();

      try {
        await navigator.clipboard.writeText(target.textContent.trim());
        copyButton.textContent = "Copied";
        copyButton.classList.add("copied");
      } catch (error) {
        copyButton.textContent = "Copy failed";
      }

      window.setTimeout(function () {
        copyButton.textContent = originalLabel;
        copyButton.classList.remove("copied");
      }, 1600);
    });
  </script>
</body>

</html>
